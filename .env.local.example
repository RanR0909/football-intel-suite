# ================================================================
# AI / 抓取密钥 — 模板文件
# 使用：cp .env.local.example .env.local 并填入真实值
# 注意：.env.local 已在 .gitignore，永不提交
# ================================================================

# Claude API（默认中转：flashapi.top）
CLAUDE_API_KEY=

# Anthropic 官方端点（备用 / fallback；可与上方共存）
ANTHROPIC_API_KEY=

# X (Twitter) v2 Bearer Token — 可选，未配置时社媒抓取自动跳过 X 源
# 申请：https://developer.x.com → Apps → Keys and tokens → Bearer Token
X_BEARER_TOKEN=

# Google Custom Search（商业新闻抓取）— 可选，未配置时整源跳过
# 申请：
#   GOOGLE_API_KEY → https://console.cloud.google.com/apis/credentials（启用 Custom Search API）
#   GOOGLE_CSE_ID  → https://programmablesearchengine.google.com/（创建搜索引擎，复制 cx）
# 免费层：100 query/day（够 9 个竞品 × 1 次/天）
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
