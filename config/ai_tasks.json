{
  "version": 2,
  "_doc": "AI 任务统一配置 v2.0（2026-05-06 加 task #5/6/7）。7 个任务，全部 haiku 4.5，全部输出 JSON。原则：AI 只做结构化工作（分类/抽取/归一/翻译/短事实陈述），不做主观判断/不写长文/不提建议/不做情感分析。",
  "endpoints": {
    "flashapi": {
      "_doc": "中转代理（默认）",
      "url": "https://ai.flashapi.top/v1/messages",
      "provider": "anthropic",
      "auth_header": "x-api-key",
      "api_key_env": "CLAUDE_API_KEY",
      "extra_headers": {
        "anthropic-version": "2023-06-01"
      },
      "verify_ssl": false
    },
    "anthropic_official": {
      "_doc": "Anthropic 官方端点（备用 / fallback）",
      "url": "https://api.anthropic.com/v1/messages",
      "provider": "anthropic",
      "auth_header": "x-api-key",
      "api_key_env": "ANTHROPIC_API_KEY",
      "extra_headers": {
        "anthropic-version": "2023-06-01"
      },
      "verify_ssl": true
    }
  },
  "models": {
    "haiku_4_5": {
      "_doc": "Claude Haiku 4.5 — 唯一在用的模型，所有任务共用",
      "name": "claude-haiku-4-5-20251001",
      "endpoint": "flashapi",
      "fallback_endpoint": "anthropic_official",
      "fallback_on_status": [502, 503, 504, 429],
      "timeout": 60,
      "max_tokens": 2048,
      "temperature": 0.1,
      "retries": 2,
      "retry_backoff": [3, 6]
    }
  },
  "tasks": {
    "comment_label": {
      "_doc": "任务 1 — 单条评论翻译为中文 + 打 6 类标签之一。输出 JSON。",
      "model": "haiku_4_5",
      "output_format": "json",
      "json_strip_markdown": true,
      "max_tokens": 1024,
      "prompt": {
        "file": "ai_tasks/prompts/comment_label.txt"
      }
    },
    "entity_extract": {
      "_doc": "任务 2 — 从已翻译评论中抽 9 类实体，配 canonical_id 归一。输出 JSON。",
      "model": "haiku_4_5",
      "output_format": "json",
      "json_strip_markdown": true,
      "max_tokens": 2048,
      "prompt": {
        "file": "ai_tasks/prompts/entity_extract.txt"
      }
    },
    "alert_title": {
      "_doc": "任务 3 — 把 alert metadata 翻译成 ≤50 字事实陈述。输出 JSON。",
      "model": "haiku_4_5",
      "output_format": "json",
      "json_strip_markdown": true,
      "max_tokens": 256,
      "temperature": 0.0,
      "prompt": {
        "file": "ai_tasks/prompts/alert_title.txt"
      }
    },
    "app_classifier": {
      "_doc": "任务 4 — App Store/GP metadata → is_relevant + topic(8 选 1) + categories(8 多选)",
      "model": "haiku_4_5",
      "output_format": "json",
      "json_strip_markdown": true,
      "max_tokens": 512,
      "temperature": 0.0,
      "prompt": {
        "file": "ai_tasks/prompts/app_classifier.txt"
      }
    },
    "news_classifier": {
      "_doc": "任务 5 — Google News 商业新闻过滤 + 8 类 category 分类。输出 JSON。",
      "model": "haiku_4_5",
      "output_format": "json",
      "json_strip_markdown": true,
      "max_tokens": 256,
      "temperature": 0.0,
      "prompt": {
        "file": "ai_tasks/prompts/news_classifier.txt"
      }
    },
    "post_topic_classifier": {
      "_doc": "任务 6 — Reddit/Twitter 帖子 → primary_topic(8 选 1) + secondary(0-2) + competitor_mentioned。",
      "model": "haiku_4_5",
      "output_format": "json",
      "json_strip_markdown": true,
      "max_tokens": 256,
      "temperature": 0.0,
      "prompt": {
        "file": "ai_tasks/prompts/post_topic.txt"
      }
    },
    "ad_selling_point": {
      "_doc": "任务 7 — Meta 广告创意 → selling_points(8 多选) + audience(5 单) + tone(4 单)。",
      "model": "haiku_4_5",
      "output_format": "json",
      "json_strip_markdown": true,
      "max_tokens": 256,
      "temperature": 0.0,
      "prompt": {
        "file": "ai_tasks/prompts/ad_selling_point.txt"
      }
    },
    "entity_translate": {
      "_doc": "任务 8 — entity_aliases.primary_name (多语言) → 简洁中文 (≤10字名词性短语)。GP 评论 4 个聚合 tab 主题名展示用。",
      "model": "haiku_4_5",
      "output_format": "json",
      "json_strip_markdown": true,
      "max_tokens": 128,
      "temperature": 0.0,
      "prompt": {
        "file": "ai_tasks/prompts/entity_translate.txt"
      }
    }
  }
}
