{
  "version": 2,
  "_doc": "AI 任务统一配置 v2.0（2026-04-30 重构）。3 个任务，全部 haiku 4.5，全部输出 JSON。原则：AI 只做结构化工作（分类/抽取/归一/翻译/短事实陈述），不做主观判断/不写长文/不提建议/不做情感分析。",
  "endpoints": {
    "flashapi": {
      "_doc": "中转代理（默认）",
      "url": "https://ai.flashapi.top/v1/messages",
      "provider": "anthropic",
      "auth_header": "x-api-key",
      "api_key_env": "CLAUDE_API_KEY",
      "extra_headers": {
        "anthropic-version": "2023-06-01"
      },
      "verify_ssl": false
    },
    "anthropic_official": {
      "_doc": "Anthropic 官方端点（备用 / fallback）",
      "url": "https://api.anthropic.com/v1/messages",
      "provider": "anthropic",
      "auth_header": "x-api-key",
      "api_key_env": "ANTHROPIC_API_KEY",
      "extra_headers": {
        "anthropic-version": "2023-06-01"
      },
      "verify_ssl": true
    }
  },
  "models": {
    "haiku_4_5": {
      "_doc": "Claude Haiku 4.5 — 唯一在用的模型，所有任务共用",
      "name": "claude-haiku-4-5-20251001",
      "endpoint": "flashapi",
      "fallback_endpoint": "anthropic_official",
      "fallback_on_status": [502, 503, 504, 429],
      "timeout": 60,
      "max_tokens": 2048,
      "temperature": 0.1,
      "retries": 2,
      "retry_backoff": [3, 6]
    }
  },
  "tasks": {
    "comment_label": {
      "_doc": "任务 1 — 单条评论翻译为中文 + 打 6 类标签之一。输出 JSON。",
      "model": "haiku_4_5",
      "output_format": "json",
      "json_strip_markdown": true,
      "max_tokens": 1024,
      "prompt": {
        "file": "ai_tasks/prompts/comment_label.txt"
      }
    },
    "entity_extract": {
      "_doc": "任务 2 — 从已翻译评论中抽 9 类实体，配 canonical_id 归一。输出 JSON。",
      "model": "haiku_4_5",
      "output_format": "json",
      "json_strip_markdown": true,
      "max_tokens": 2048,
      "prompt": {
        "file": "ai_tasks/prompts/entity_extract.txt"
      }
    },
    "alert_title": {
      "_doc": "任务 3 — 把 alert metadata 翻译成 ≤50 字事实陈述。输出 JSON。",
      "model": "haiku_4_5",
      "output_format": "json",
      "json_strip_markdown": true,
      "max_tokens": 256,
      "temperature": 0.0,
      "prompt": {
        "file": "ai_tasks/prompts/alert_title.txt"
      }
    }
  }
}
